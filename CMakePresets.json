{
  "version": 6,
  "configurePresets": [
    {
      "name": "ninja-multi",
      "description": "use Ninja Multi-Configure generator",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_GENERATOR": "Ninja Multi-Config",
        "CMAKE_VERBOSE_MAKEFILE": "ON"
      }
    },
    {
      "name": "default-config",
      "description": "default configurations",
      "hidden": true,
      "binaryDir": "${sourceDir}/__out/build/${presetName}",
      "cacheVariables": {
        "CPM_SOURCE_CACHE": "~/.cache/CPM"
      },
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "toolset": {
        "value": "host=x64",
        "strategy": "external"
      }
    },
    {
      "name": "windows_default",
      "description": "Windows default configuration",
      "displayName": "Windows Default",
      "inherits": [
        "ninja-multi",
        "default-config"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "Debug",
      "description": "",
      "displayName": "",
      "configurePreset": "windows_default",
      "configuration": "Debug"
    },
    {
      "name": "Release",
      "description": "",
      "displayName": "",
      "configurePreset": "windows_default",
      "configuration": "Release"
    }
  ]
}